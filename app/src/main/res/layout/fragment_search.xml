<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="#F8F6F5">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_sort_by_size" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LUMIÈRE"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#111111"
            android:layout_centerInParent="true" />

        <ImageView
            android:id="@+id/btnCart"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_share" />

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E7E2DE" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SEARCH BOX -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_search_box">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="19dp"
                    android:src="@android:drawable/ic_menu_search" />

                <EditText
                    android:id="@+id/edtSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="Tìm kiếm sản phẩm"
                    android:textColor="#111111"
                    android:textColorHint="#B1AAA6"
                    android:textSize="14sp"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnSearch"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:text="Tìm"
                    app:backgroundTint="#0a0a0a" />

            </LinearLayout>
            <!-- SEARCH RESULT -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_product" />
            <TextView
                android:id="@+id/tvNoResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Không có sản phẩm phù hợp"
                android:textSize="16sp"
                android:textColor="#888888"
                android:visibility="gone" />


            <!-- RECENT -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TÌM KIẾM GẦN ĐÂY"
                    android:textSize="13sp"
                    android:letterSpacing="0.08"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/tvClearAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xóa tất cả"
                    android:textColor="#9B9591"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true" />

            </RelativeLayout>

            <!-- RECENT CHIPS CONTAINER -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/recentChipsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Dynamic chips will be added here -->
                </LinearLayout>
            </HorizontalScrollView>

            <!-- TREND -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XU HƯỚNG HIỆN NAY"
                android:textSize="13sp"
                android:letterSpacing="0.08"
                android:textColor="#111111"
                android:layout_marginTop="40dp" />

            <!-- TREND CHIPS CONTAINER (Dynamic - Top rated products) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/trendChipsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Dynamic chips will be added here -->
                </LinearLayout>
            </HorizontalScrollView>

            <!-- SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BIÊN TẬP CHO BẠN"
                android:textSize="14sp"
                android:textColor="#111111"
                android:letterSpacing="0.08"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="60dp" />

            <!-- CARD 1 SAFE -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="24dp"

                android:background="@drawable/bg_card_radius">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/fashion1"
                    android:scaleType="centerCrop"
                    />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="18dp"
                    android:text="HÀNG MỚI VỀ"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- CARD 2 SAFE -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_card_radius_2">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/fashion2"
                    android:scaleType="centerCrop"
                    />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="18dp"
                    android:text="PHONG CÁCH"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </FrameLayout>

        </LinearLayout>

    </ScrollView>


</LinearLayout>