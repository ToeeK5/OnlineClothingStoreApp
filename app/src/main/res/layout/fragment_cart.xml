<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cartScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/cartRootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="@color/text_dark"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/txtLogo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/app_name"
                android:textColor="@color/text_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnBag"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_upload"
                android:tint="@color/text_dark"
                tools:ignore="UseAppTint" />

        </LinearLayout>

        <View
            android:id="@+id/headerDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- TITLE -->
        <TextView
            android:id="@+id/txtYourChoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.08"
            android:text="@string/your_choice"
            android:textAllCaps="true"
            android:textColor="@color/text_gray"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtShoppingBag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:fontFamily="serif"
            android:text="@string/shopping_bag"
            android:textColor="@color/text_dark"
            android:textSize="36sp" />

        <!-- PRODUCT 1 -->
        <LinearLayout
            android:id="@+id/itemProductOne"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="20dp"
            android:orientation="horizontal"
            android:paddingBottom="14dp">

            <ImageView
                android:id="@+id/imgProductOne"
                android:layout_width="96dp"
                android:layout_height="126dp"
                android:background="@drawable/bg_product_image"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder" />

            <LinearLayout
                android:id="@+id/productOneInfoLayout"
                android:layout_width="0dp"
                android:layout_height="126dp"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/productOneTitleRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtProductOneName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:maxLines="2"
                        android:text="@string/product_coat_name"
                        android:textColor="@color/text_dark"
                        android:textSize="20sp" />

                    <ImageView
                        android:id="@+id/btnDeleteProductOne"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_delete"
                        android:tint="@color/text_dark"
                        tools:ignore="UseAppTint" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtProductOneVariant"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/product_coat_variant"
                        android:textAllCaps="true"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/productOneQtyBox"
                        android:layout_width="96dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_qty_box"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnMinusProductOne"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/minus"
                            android:textColor="@color/text_dark"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/txtQtyProductOne"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/default_quantity"
                            android:textColor="@color/text_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnPlusProductOne"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/plus"
                            android:textColor="@color/text_dark"
                            android:textSize="20sp" />

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/txtProductOnePrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:gravity="end"
                    android:text="@string/product_coat_price"
                    android:textColor="@color/text_dark"
                    android:textSize="22sp" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/productDividerOne"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@color/divider" />

        <!-- PRODUCT 2 -->
        <LinearLayout
            android:id="@+id/itemProductTwo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:orientation="horizontal"
            android:paddingBottom="14dp">

            <ImageView
                android:id="@+id/imgProductTwo"
                android:layout_width="96dp"
                android:layout_height="126dp"
                android:background="@drawable/bg_product_image"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder" />

            <LinearLayout
                android:id="@+id/productTwoInfoLayout"
                android:layout_width="0dp"
                android:layout_height="126dp"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/productTwoTitleRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtProductTwoName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:maxLines="2"
                        android:text="@string/product_pants_name"
                        android:textColor="@color/text_dark"
                        android:textSize="20sp" />

                    <ImageView
                        android:id="@+id/btnDeleteProductTwo"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_delete"
                        android:tint="@color/text_dark"
                        tools:ignore="UseAppTint" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtProductTwoVariant"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/product_pants_variant"
                        android:textAllCaps="true"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/productTwoQtyBox"
                        android:layout_width="96dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_qty_box"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnMinusProductTwo"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/minus"
                            android:textColor="@color/text_dark"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/txtQtyProductTwo"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/default_quantity"
                            android:textColor="@color/text_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnPlusProductTwo"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/plus"
                            android:textColor="@color/text_dark"
                            android:textSize="20sp" />

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/txtProductTwoPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:gravity="end"
                    android:text="@string/product_pants_price"
                    android:textColor="@color/text_dark"
                    android:textSize="22sp" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/productDividerTwo"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@color/divider" />

        <!-- ORDER SUMMARY -->
        <LinearLayout
            android:id="@+id/orderSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_summary_card"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/txtOrderSummaryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/order_summary"
                android:textAllCaps="true"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/subtotalRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtSubtotalLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/subtotal"
                    android:textColor="@color/text_gray"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/txtSubtotalValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtotal_value"
                    android:textColor="@color/text_dark"
                    android:textSize="17sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/shippingRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtShippingLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/shipping_fee"
                    android:textColor="@color/text_gray"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/txtShippingValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/free_shipping"
                    android:textColor="@color/text_dark"
                    android:textSize="17sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/taxRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtTaxLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/tax"
                    android:textColor="@color/text_gray"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/txtTaxValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tax_value"
                    android:textColor="@color/text_dark"
                    android:textSize="17sp" />

            </LinearLayout>

            <View
                android:id="@+id/summaryDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="22dp"
                android:background="@color/divider" />

            <LinearLayout
                android:id="@+id/totalRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtTotalLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="@string/total"
                    android:textColor="@color/text"
                    android:textSize="26sp" />

                <TextView
                    android:id="@+id/txtTotalValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="@string/total_value"
                    android:textColor="@color/text_dark"
                    android:textSize="26sp" />

            </LinearLayout>

            <Button
                android:id="@+id/btnCheckoutNow"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_checkout_button"
                android:letterSpacing="0.2"
                android:text="@string/checkout_now"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/secureTransactionLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgSecureIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_lock_lock"
                android:tint="@color/text_light"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/txtSecureTransaction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/secure_transaction"
                android:textAllCaps="true"
                android:textColor="@color/text_light"
                android:textSize="13sp" />

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>

</ScrollView>